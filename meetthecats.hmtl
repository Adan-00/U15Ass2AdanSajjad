<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meet The Cats | Whisker's Café</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Caveat:wght@700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:'Poppins',sans-serif;
background:#F5EFE8;
color:#4A342E;
overflow-x:hidden;
}

/* Floating Paw Prints */

.paw{
position:fixed;
font-size:28px;
opacity:0.05;
pointer-events:none;
animation:floatPaw 15s linear infinite;
z-index:-1;
}

@keyframes floatPaw{
from{
transform:translateY(110vh);
}
to{
transform:translateY(-120vh) rotate(360deg);
}
}

/* NAVBAR */

.navbar{
position:sticky;
top:0;
z-index:1000;

display:flex;
justify-content:space-between;
align-items:center;

padding:15px 40px;

background:rgba(123,90,80,0.95);
backdrop-filter:blur(10px);
}

.logo{
font-size:1.5rem;
font-weight:700;
color:white;
}

.nav-links{
display:flex;
gap:20px;
list-style:none;
flex-wrap:wrap;
}

.nav-links a{
text-decoration:none;
color:white;
font-weight:600;
transition:.3s;
}

.nav-links a:hover{
color:#F5EDE4;
}

/* HERO */

.hero{
height:70vh;

display:flex;
justify-content:center;
align-items:center;
text-align:center;

background:
linear-gradient(rgba(0,0,0,.25),rgba(0,0,0,.25)),
url("https://images.unsplash.com/photo-1511044568932-338cba0ad803");

background-size:cover;
background-position:center;
}

.hero h1{
font-family:'Caveat',cursive;
font-size:5rem;
color:white;
}

.hero p{
color:white;
font-size:1.2rem;
margin-top:10px;
}

/* REVEAL */

.reveal{
opacity:0;
transform:translateY(50px);
filter:blur(10px);
transition:1s;
}

.reveal.active{
opacity:1;
transform:none;
filter:none;
}

/* CAT OF WEEK */

.featured{
width:90%;
margin:50px auto;
background:#CBA889;
padding:50px;
border-radius:30px;
text-align:center;
color:white;
}

/* SEARCH */

.search-section{
text-align:center;
margin:40px;
}

.search-section input{
width:350px;
max-width:90%;
padding:15px;
border:none;
border-radius:30px;
}

/* CATS GRID */

.cats-grid{
width:90%;
margin:auto;

display:grid;
grid-template-columns:repeat(4,1fr);

gap:25px;
}

.cat-card{
background:white;
border-radius:25px;
overflow:hidden;

box-shadow:0 10px 25px rgba(0,0,0,.08);

transition:.4s;
}

.cat-card:hover{
transform:translateY(-10px);
}

.cat-card img{
width:100%;
height:250px;
object-fit:cover;
}

.cat-content{
padding:20px;
text-align:center;
}

.badge{
display:inline-block;
padding:6px 12px;
background:#E8F7E8;
border-radius:20px;
margin:10px;
}

button{
background:#9B745E;
color:white;
border:none;
padding:12px 20px;
border-radius:30px;
cursor:pointer;
}

/* STATS */

.stats{
width:90%;
margin:60px auto;

display:grid;
grid-template-columns:repeat(3,1fr);

gap:20px;
}

.stat{
background:white;
padding:30px;
border-radius:20px;
text-align:center;
}

/* ADOPT */

.adopt{
width:90%;
margin:50px auto;
background:#8B5E52;
padding:60px;
border-radius:30px;
text-align:center;
color:white;
}

/* MODAL */

.modal{
display:none;
position:fixed;
inset:0;
background:rgba(0,0,0,.5);
backdrop-filter:blur(8px);
justify-content:center;
align-items:center;
z-index:9999;
}

.modal-content{
background:white;
padding:30px;
border-radius:25px;
max-width:500px;
width:90%;
text-align:center;
}

.close{
font-size:30px;
cursor:pointer;
float:right;
}

/* FOOTER */

footer{
margin-top:50px;
background:white;
padding:25px;
text-align:center;
font-weight:700;
}

/* MOBILE */

@media(max-width:1000px){

.cats-grid{
grid-template-columns:repeat(2,1fr);
}

}

@media(max-width:700px){

.cats-grid,
.stats{
grid-template-columns:1fr;
}

.navbar{
flex-direction:column;
gap:15px;
}

.hero h1{
font-size:3rem;
}

}

</style>
</head>

<body>

<div class="paw" style="left:10%">🐾</div>
<div class="paw" style="left:35%;animation-delay:4s">🐾</div>
<div class="paw" style="left:65%;animation-delay:8s">🐾</div>

<nav class="navbar">

<div class="logo">
🐾 Whisker's Café
</div>

<ul class="nav-links">
<li><a href="index.html">Home</a></li>
<li><a href="meetthecats.html">Meet The Cats</a></li>
<li><a href="menu.html">Menu</a></li>
<li><a href="book.html">Book</a></li>
<li><a href="adopt.html">Adopt</a></li>
<li><a href="merchandise.html">Merchandise</a></li>
<li><a href="about.html">About Us</a></li>
<li><a href="contact.html">Contact</a></li>
</ul>

</nav>

<section class="hero">

<div>

<h1>Meet The Cats 🐱</h1>

<p>
The real owners of Whisker's Café.
</p>

</div>

</section>

<section class="featured reveal">

<h2>⭐ Cat Of The Week ⭐</h2>

<h3>Larry</h3>

<p>
Professional gentleman. Biscuit investigator. 10/10 loaf.
</p>

</section>

<section class="search-section">

<input type="text" placeholder="🔍 Search cats...">

</section>

<section class="cats-grid">

<div class="cat-card reveal">
<img src="https://i.pinimg.com/736x/32/3a/9e/323a9eafe64e057cfb489e8d1e1ec5b9.jpg">
<div class="cat-content">
<h3>Poppy</h3>
<div class="badge">Available</div>
<button onclick="openModal('poppy')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/736x/b2/d1/c9/b2d1c98dfe0b7585107a2ba8a646c0c6.jpg">
<div class="cat-content">
<h3>Larry</h3>
<div class="badge">Available</div>
<button onclick="openModal('larry')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/1200x/31/8c/17/318c176f3f0ab7d58e7959c915366c31.jpg">
<div class="cat-content">
<h3>Lady Gaga</h3>
<div class="badge">Available</div>
<button onclick="openModal('gaga')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/736x/69/d4/f5/69d4f553a801270cc080e78402855353.jpg">
<div class="cat-content">
<h3>Mr Beans</h3>
<div class="badge">Available</div>
<button onclick="openModal('beans')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/736x/40/2c/39/402c392f146b4397b1c5ad735943f284.jpg">
<div class="cat-content">
<h3>Angry Bird</h3>
<div class="badge">Available</div>
<button onclick="openModal('bird')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/736x/90/ad/e9/90ade9eb843b86d94791e7eef15a8313.jpg">
<div class="cat-content">
<h3>Hairy Pawter</h3>
<div class="badge">Available</div>
<button onclick="openModal('pawter')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/1200x/8b/0b/84/8b0b8406f96ee06143f331db1b8dc168.jpg">
<div class="cat-content">
<h3>Paw McCartney</h3>
<div class="badge">Available</div>
<button onclick="openModal('mccartney')">Show Details</button>
</div>
</div>

<div class="cat-card reveal">
<img src="https://i.pinimg.com/736x/0f/42/3d/0f423d1914b8fc016cb7544adde32f24.jpg">
<div class="cat-content">
<h3>Purrlock Holmes</h3>
<div class="badge">Available</div>
<button onclick="openModal('purrlock')">Show Details</button>
</div>
</div>

</section>

<section class="stats">

<div class="stat reveal">
<h2>127</h2>
<p>Cats Rehomed</p>
</div>

<div class="stat reveal">
<h2>4921</h2>
<p>Coffees Served</p>
</div>

<div class="stat reveal">
<h2>98%</h2>
<p>Customer Happiness</p>
</div>

</section>

<section class="adopt reveal">

<h2>❤️ Looking For A Forever Friend?</h2>

<p>
Many of our cats are looking for loving homes.
Visit our Adopt page to learn more.
</p>

</section>

<div class="modal" id="modal">

<div class="modal-content">

<span class="close" onclick="closeModal()">&times;</span>

<div id="modalText"></div>

</div>

</div>

<footer>

Whisker's Café © 2026

</footer>

<script>

const observer = new IntersectionObserver(entries => {

entries.forEach(entry => {

if(entry.isIntersecting){

entry.target.classList.add("active");

}

});

});

document.querySelectorAll(".reveal").forEach(el => {
observer.observe(el);
});

function openModal(cat){

const cats={

poppy:"🐱 POPPY<br><br>Wanted for nugget theft.",
larry:"🐱 LARRY<br><br>Professional gentleman.",
gaga:"🐱 LADY GAGA<br><br>Main character syndrome.",
beans:"🐱 MR BEANS<br><br>Runs on chaos.",
bird:"🐱 ANGRY BIRD<br><br>Perpetually offended.",
pawter:"🐱 HAIRY PAWTER<br><br>Wizard level fluff.",
mccartney:"🐱 PAW MCCARTNEY<br><br>Musical genius.",
purrlock:"🐱 PURRLOCK HOLMES<br><br>Solves treat mysteries."

};

document.getElementById("modal").style.display="flex";
document.getElementById("modalText").innerHTML=cats[cat];

}

function closeModal(){
document.getElementById("modal").style.display="none";
}

</script>

</body>
</html>
